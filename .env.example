# Google Cloud service account key — required to run `npm run generate:audio`
# Only needed at build time; never exposed to the browser.
# Download your service account JSON from Google Cloud Console → IAM → Service Accounts.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# Recraft API key — required to run `npm run generate:images`
# Only needed at build time; never exposed to the browser.
# Get your key at https://www.recraft.ai → Account → API Keys
RECRAFT_API_KEY=your_recraft_api_key_here
